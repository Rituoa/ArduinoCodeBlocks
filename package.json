{
  "name": "arduinocodeblocks",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "server": "json-server --watch db.json --port 5000",
    "react:build": "vite build",
    "app:dist": "npm run react:build && electron-builder"
  },
  "dependencies": {
    "@wokwi/elements": "^1.9.2",
    "avr8js": "^0.21.0",
    "blockly": "^12.0.0",
    "http-proxy-middleware": "^3.0.0",
    "json-server": "^0.17.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "vite": "^8.1.5"
  },
  "build": {
    "appId": "com.robonist.ardublock",
    "productName": "Robonist IDE",
    "directories": {
      "output": "release/"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
