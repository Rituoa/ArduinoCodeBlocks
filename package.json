{
  "name": "arduinocodeblocks",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "server": "json-server --watch db.json --port 5000",
    "react:build": "vite build",
    "app:dist": "npm run react:build && electron-builder"
  },
  "dependencies": {
    "@wokwi/elements": "^... (keep your versions)",
    "avr8js": "^...",
    "blockly": "^...",
    "http-proxy-middleware": "^3.0.0",
    "json-server": "^0.17.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.1"
  },
  "build": {
    "appId": "com.robonist.ardublock",
    "productName": "Robonist IDE",
    "directories": {
      "output": "release/"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
